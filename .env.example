# Trading Agent Environment Variables
# Copy this file to .env and fill in your actual values

# ==================== LLM API Keys ====================

# Volcengine (ByteDance/Doubao)
VOLCENGINE_API_KEY=your_volcengine_api_key_here
VOLCENGINE_ENDPOINT_ID=your_endpoint_id_here

# Zhipu (GLM)
ZHIPU_API_KEY=your_zhipu_api_key_here

# OpenAI (fallback)
OPENAI_API_KEY=your_openai_api_key_here

# ==================== Feishu Push ====================

FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_id

# ==================== Email Push (Optional) ====================

EMAIL_SMTP=smtp.example.com
EMAIL_USER=your_email@example.com
EMAIL_PASSWORD=your_email_password
EMAIL_TO=recipient@example.com

# ==================== TrendRadar MCP ====================

TRENDRADAR_MCP_PATH=/path/to/TrendRadar/mcp_server

# ==================== Proxy (Optional) ====================

# For akshare if network requires proxy
HTTP_PROXY=
HTTPS_PROXY=